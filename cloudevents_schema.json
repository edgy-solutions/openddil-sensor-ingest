{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudEvents Envelope",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "data": {
      "type": "object"
    }
  },
  "required": [
    "id",
    "source",
    "type",
    "time",
    "datacontenttype",
    "data"
  ],
  "additionalProperties": true
}
